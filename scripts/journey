#!/usr/bin/env python3
"""journey — DSA-journey mastery checkpoint CLI.

Usage:
  ./scripts/journey quiz N            Quiz on Week N
  ./scripts/journey quiz N --n 3      Only 3 random questions
  ./scripts/journey quiz all          Cross-week mix
  ./scripts/journey progress          Show progress table
  ./scripts/journey reset N           Reset Week N progress
  ./scripts/journey                   Resume from current week

The CLI reads `Week N/mastery.yml` files and persists results to
`~/.journey/progress.json`. Set JOURNEY_NON_INTERACTIVE=1 to auto-fill
correct answers (useful for CI smoke tests).
"""

from __future__ import annotations

import argparse
import datetime as _dt
import html as _html
import json
import os
import random
import re
import subprocess
import sys
import webbrowser
from pathlib import Path

try:
    import yaml  # PyYAML
except ImportError:
    sys.stderr.write(
        "error: PyYAML is required. Install with: pip install pyyaml\n"
    )
    sys.exit(2)

REPO_ROOT = Path(__file__).resolve().parent.parent
PROGRESS_DIR = Path(os.path.expanduser("~/.journey"))
PROGRESS_FILE = PROGRESS_DIR / "progress.json"
TOTAL_WEEKS = 30
NON_INTERACTIVE = os.environ.get("JOURNEY_NON_INTERACTIVE") == "1"

# ---------------------------------------------------------------------------
# FSRS (Free Spaced Repetition Scheduler) — minimum viable implementation.
#
# Reference: https://github.com/open-spaced-repetition/fsrs4anki (not a dep,
# just the canonical source for the algorithm and default weights). FSRS
# models each card's memory as two latent variables — Difficulty (D, 1-10)
# and Stability (S, days) — and picks the next review interval so the
# learner's retrievability hits a target retention rate (default 0.9).
#
# We use the published FSRS v4 default weights `w` (17 of them) but skip the
# learn-to-rank training — these defaults are good enough out of the box.
# ---------------------------------------------------------------------------

# Default FSRS v4 weights (published parameters from fsrs4anki).
FSRS_W = [
    0.4, 0.6, 2.4, 5.8,         # initial stability per first-rating
    4.93, 0.94, 0.86, 0.01,     # initial difficulty + update params
    1.49, 0.14, 0.94,           # stability-after-success curve
    2.18, 0.05, 0.34,           # stability-after-failure curve
    1.26, 0.29, 2.61,           # interval and damping
]
FSRS_REQUEST_RETENTION = 0.9
FSRS_MAX_INTERVAL = 365  # days — we cap so "mastered" still shows up yearly

# Ratings: 1=again, 2=hard, 3=good, 4=easy (matches Anki convention).
RATING_AGAIN, RATING_HARD, RATING_GOOD, RATING_EASY = 1, 2, 3, 4


def _today() -> _dt.date:
    return _dt.date.today()


def _parse_date(s: str | None) -> _dt.date | None:
    if not s:
        return None
    try:
        return _dt.date.fromisoformat(s[:10])
    except Exception:
        return None


def fsrs_init_state(rating: int) -> dict:
    """Create initial SRS state from the first review's rating."""
    # FSRS_W[0..3] give initial stability per rating (1..4).
    s = max(0.1, FSRS_W[max(0, min(3, rating - 1))])
    # FSRS_W[4] is initial difficulty intercept; FSRS_W[5] scales by rating.
    d = FSRS_W[4] - FSRS_W[5] * (rating - 3)
    d = min(10.0, max(1.0, d))
    today = _today()
    interval = _fsrs_next_interval(s)
    return {
        "difficulty": d,
        "stability": s,
        "last_review_date": today.isoformat(),
        "next_review_date": (today + _dt.timedelta(days=interval)).isoformat(),
        "reps": 1,
        "lapses": 1 if rating == RATING_AGAIN else 0,
        "history": [{"date": today.isoformat(), "rating": rating}],
    }


def _fsrs_next_interval(stability: float) -> int:
    """Days until retrievability falls to FSRS_REQUEST_RETENTION."""
    import math
    if stability <= 0:
        return 1
    # FSRS retrievability model: R(t) = (1 + t/(9*S))^(-1)
    factor = (FSRS_REQUEST_RETENTION ** (-1 / FSRS_W[16]) - 1) * 9
    ivl = stability * factor
    return max(1, min(FSRS_MAX_INTERVAL, int(round(ivl))))


def _fsrs_update_difficulty(d: float, rating: int) -> float:
    # Linear adjustment toward target; FSRS_W[6] is the learning rate.
    d_new = d - FSRS_W[6] * (rating - 3)
    # Mean-reversion toward the rating-3 baseline.
    d_new = FSRS_W[7] * FSRS_W[4] + (1 - FSRS_W[7]) * d_new
    return min(10.0, max(1.0, d_new))


def _fsrs_update_stability(s: float, d: float, rating: int, retrievability: float) -> float:
    import math
    if rating == RATING_AGAIN:
        # Stability after a lapse — much smaller, scaled by current d and s.
        s_new = (
            FSRS_W[11]
            * (d ** -FSRS_W[12])
            * ((s + 1) ** FSRS_W[13] - 1)
            * math.exp((1 - retrievability) * FSRS_W[14])
        )
        return max(0.1, s_new)
    # Stability after a success — grows multiplicatively.
    hard_penalty = 1.0 if rating != RATING_HARD else FSRS_W[15]
    easy_bonus = 1.0 if rating != RATING_EASY else FSRS_W[16]
    s_new = s * (
        1
        + math.exp(FSRS_W[8])
        * (11 - d)
        * (s ** -FSRS_W[9])
        * (math.exp((1 - retrievability) * FSRS_W[10]) - 1)
        * hard_penalty
        * easy_bonus
    )
    return max(0.1, min(36500.0, s_new))


def _fsrs_retrievability(s: float, days_elapsed: float) -> float:
    if s <= 0:
        return 0.0
    return (1 + days_elapsed / (9 * s)) ** -FSRS_W[16]


def fsrs_update(state: dict, rating: int) -> dict:
    """Update a per-skill SRS state with a new rating (1..4)."""
    import math
    today = _today()
    last = _parse_date(state.get("last_review_date")) or today
    days_elapsed = max(0, (today - last).days)
    s_old = float(state.get("stability", 0.5))
    d_old = float(state.get("difficulty", FSRS_W[4]))
    r = _fsrs_retrievability(s_old, days_elapsed)
    d_new = _fsrs_update_difficulty(d_old, rating)
    s_new = _fsrs_update_stability(s_old, d_new, rating, r)
    ivl = _fsrs_next_interval(s_new)
    new = dict(state)
    new["difficulty"] = d_new
    new["stability"] = s_new
    new["last_review_date"] = today.isoformat()
    new["next_review_date"] = (today + _dt.timedelta(days=ivl)).isoformat()
    new["reps"] = int(state.get("reps", 0)) + 1
    new["lapses"] = int(state.get("lapses", 0)) + (1 if rating == RATING_AGAIN else 0)
    history = list(state.get("history", []))
    history.append({"date": today.isoformat(), "rating": rating})
    new["history"] = history[-50:]   # cap history to avoid unbounded growth
    return new


def rating_from_correct(ok: bool) -> int:
    """Auto-rate: correct → good (3), incorrect → again (1)."""
    return RATING_GOOD if ok else RATING_AGAIN


def get_srs_state(progress: dict, week: int, skill_id: str) -> dict | None:
    srs = progress.get("srs_state", {})
    return srs.get(f"{week}:{skill_id}")


def set_srs_state(progress: dict, week: int, skill_id: str, state: dict) -> None:
    srs = progress.setdefault("srs_state", {})
    srs[f"{week}:{skill_id}"] = state


def is_due(state: dict, on_date: _dt.date | None = None) -> bool:
    """A skill is due if its next_review_date is today or earlier."""
    on_date = on_date or _today()
    nd = _parse_date(state.get("next_review_date"))
    return nd is None or nd <= on_date


def is_mastered(state: dict) -> bool:
    """Mastered = high stability and no recent failure."""
    if float(state.get("stability", 0.0)) < 21.0:
        return False
    history = state.get("history", [])
    recent = history[-3:]
    return all(h.get("rating", 1) != RATING_AGAIN for h in recent)


def collect_due_skills(progress: dict, max_skills: int | None = None) -> list[dict]:
    """Walk every week's mastery.yml, return skills that are due, oldest first.

    Each returned dict is the YAML skill dict plus a `_week` tag.
    Skills that have never been reviewed are NOT considered due — `review` is
    for revisiting things you've already seen at least once.
    """
    out: list[tuple[_dt.date, dict]] = []
    for n in range(1, TOTAL_WEEKS + 1):
        data = load_week(n)
        if not data:
            continue
        for skill in data.get("skills", []):
            sid = skill.get("id")
            if not sid:
                continue
            state = get_srs_state(progress, n, sid)
            if not state:
                continue
            if is_mastered(state) and not is_due(state):
                continue
            if is_due(state):
                tagged = dict(skill)
                tagged["_week"] = n
                tagged["_srs"] = state
                nd = _parse_date(state.get("next_review_date")) or _today()
                out.append((nd, tagged))
    # Priority: oldest due date first (most overdue → highest priority).
    out.sort(key=lambda t: t[0])
    skills = [s for _, s in out]
    if max_skills is not None:
        skills = skills[:max_skills]
    return skills


# ---------------------------------------------------------------------------
# Progress persistence
# ---------------------------------------------------------------------------

def load_progress() -> dict:
    if PROGRESS_FILE.exists():
        try:
            return json.loads(PROGRESS_FILE.read_text())
        except Exception:
            pass
    return {"weeks": {}, "current_week": 1}


def save_progress(data: dict) -> None:
    PROGRESS_DIR.mkdir(parents=True, exist_ok=True)
    PROGRESS_FILE.write_text(json.dumps(data, indent=2, sort_keys=True))


# ---------------------------------------------------------------------------
# YAML loading
# ---------------------------------------------------------------------------

def week_yaml_path(week: int) -> Path:
    return REPO_ROOT / f"Week {week}" / "mastery.yml"


def load_week(week: int) -> dict | None:
    path = week_yaml_path(week)
    if not path.exists():
        return None
    with path.open() as fh:
        return yaml.safe_load(fh)


def load_all_weeks() -> list[dict]:
    weeks = []
    for n in range(1, TOTAL_WEEKS + 1):
        data = load_week(n)
        if data is not None:
            weeks.append(data)
    return weeks


# ---------------------------------------------------------------------------
# Quiz engine
# ---------------------------------------------------------------------------

def _norm(s: str) -> str:
    return re.sub(r"\s+", " ", str(s).strip().lower())


def _prompt(label: str) -> str:
    if NON_INTERACTIVE:
        return ""
    try:
        return input(label)
    except EOFError:
        return ""


def ask_numeric(skill: dict) -> bool:
    expected = skill["answer"]
    if NON_INTERACTIVE:
        print(f"  (auto) answering: {expected}")
        return True
    raw = _prompt("Your answer: ").strip()
    try:
        return float(raw) == float(expected)
    except ValueError:
        return False


def ask_string(skill: dict) -> bool:
    expected = skill["answer"]
    if NON_INTERACTIVE:
        print(f"  (auto) answering: {expected}")
        return True
    raw = _prompt("Your answer: ").strip()
    return _norm(raw) == _norm(expected)


def ask_multiple_choice(skill: dict) -> bool:
    choices = skill.get("choices", [])
    for i, c in enumerate(choices):
        print(f"  {i}) {c}")
    expected = skill["answer"]
    if NON_INTERACTIVE:
        print(f"  (auto) answering: {expected}")
        return True
    raw = _prompt("Pick (index or text): ").strip()
    if raw.isdigit():
        idx = int(raw)
        if isinstance(expected, int):
            return idx == expected
        if 0 <= idx < len(choices):
            return _norm(choices[idx]) == _norm(expected)
        return False
    if isinstance(expected, int):
        return 0 <= expected < len(choices) and _norm(raw) == _norm(choices[expected])
    return _norm(raw) == _norm(expected)


def ask_list(skill: dict) -> bool:
    expected = [_norm(a) for a in skill["answer"]]
    needed = len(expected)
    print(f"  (Provide up to {needed} bullets, one per line; blank line to stop.)")
    if NON_INTERACTIVE:
        for a in skill["answer"]:
            print(f"  (auto) > {a}")
        return True
    got: set[str] = set()
    for _ in range(needed):
        raw = _prompt(f"  bullet {len(got) + 1}: ").strip()
        if not raw:
            break
        got.add(_norm(raw))
    matched = sum(1 for e in expected if any(e in g or g in e for g in got))
    # require at least floor(needed * 0.6) and >= 1
    threshold = max(1, (needed * 3 + 4) // 5)  # ~60%
    return matched >= threshold


def ask_open(skill: dict) -> bool:
    acceptable = skill.get("answer") or []
    if isinstance(acceptable, str):
        acceptable = [acceptable]
    if NON_INTERACTIVE:
        canonical = acceptable[0] if acceptable else ""
        print(f"  (auto) answering: {canonical}")
        return True
    raw = _prompt("Your answer: ").strip()
    if not raw:
        return False
    raw_n = _norm(raw)
    for a in acceptable:
        if _norm(a) in raw_n or raw_n in _norm(a):
            return True
    # Self-grade fallback
    print(f"\n  Canonical answer hints: {acceptable}")
    grade = _prompt("Did your answer cover the idea? (y/n): ").strip().lower()
    return grade.startswith("y")


HANDLERS = {
    "numeric": ask_numeric,
    "string": ask_string,
    "list": ask_list,
    "multiple_choice": ask_multiple_choice,
    "open": ask_open,
}


def _ask_rating(ok: bool) -> int:
    """Optionally let the learner self-rate; otherwise auto-derive from correctness.

    Returns one of the RATING_* constants (1..4). In non-interactive mode we
    always use the auto-derived rating so CI smoke tests stay deterministic.
    """
    auto = rating_from_correct(ok)
    if NON_INTERACTIVE:
        return auto
    hint = "again/hard/good/easy" if ok else "again/hard"
    raw = _prompt(f"  Self-rate ({hint}, blank = auto): ").strip().lower()
    if not raw:
        return auto
    if raw in ("1", "a", "again"):
        return RATING_AGAIN
    if raw in ("2", "h", "hard"):
        return RATING_HARD
    if raw in ("3", "g", "good"):
        return RATING_GOOD
    if raw in ("4", "e", "easy"):
        return RATING_EASY
    return auto


def run_quiz(
    week_data: dict,
    n: int | None = None,
    progress: dict | None = None,
) -> dict:
    skills = list(week_data.get("skills", []))
    random.shuffle(skills)
    if n is not None:
        skills = skills[:n]

    week_num = week_data.get("week", "?")
    title = week_data.get("title", "")
    print(f"\n=== Week {week_num} — {title} ===")
    print(f"{len(skills)} skill check(s). Type your answer; explanations follow each.\n")

    passed: list[str] = []
    missed: list[str] = []
    srs_updates: list[tuple[int, str, int]] = []  # (week, skill_id, rating)
    for i, skill in enumerate(skills, 1):
        sid = skill.get("id", f"skill_{i}")
        stype = skill.get("type", "open")
        # Determine the originating week for SRS bookkeeping.
        skill_week = skill.get("_week", week_num if isinstance(week_num, int) else None)
        print(f"[{i}/{len(skills)}] ({stype}) {skill['prompt']}")
        handler = HANDLERS.get(stype, ask_open)
        try:
            ok = handler(skill)
        except KeyboardInterrupt:
            print("\nInterrupted.")
            break
        if ok:
            print(f"  PASS — {skill.get('explanation', '')}\n")
            passed.append(sid)
        else:
            ans = skill.get("answer")
            print(f"  MISS — answer: {ans}")
            print(f"         {skill.get('explanation', '')}\n")
            missed.append(sid)
        rating = _ask_rating(ok)
        if isinstance(skill_week, int):
            srs_updates.append((skill_week, sid, rating))

    total = len(passed) + len(missed)
    rate = (100 * len(passed) / total) if total else 0
    print(f"=== Summary: {len(passed)}/{total} passed ({rate:.0f}%) ===")
    if missed:
        print("Skills missed: " + ", ".join(missed))

    # Apply SRS updates if we were given a progress dict to mutate.
    if progress is not None:
        for wk, sid, rating in srs_updates:
            existing = get_srs_state(progress, wk, sid)
            new_state = (
                fsrs_update(existing, rating) if existing else fsrs_init_state(rating)
            )
            set_srs_state(progress, wk, sid, new_state)

    return {
        "week": week_num,
        "passed": passed,
        "missed": missed,
        "total": total,
        "rate": rate,
        "timestamp": _dt.date.today().isoformat(),
    }


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_quiz(args: argparse.Namespace) -> int:
    progress = load_progress()
    target = args.target

    if target == "all":
        all_weeks = load_all_weeks()
        if not all_weeks:
            print("No mastery.yml files found.")
            return 1
        mixed_skills = []
        for w in all_weeks:
            for s in w.get("skills", []):
                tagged = dict(s)
                tagged["_week"] = w.get("week")
                mixed_skills.append(tagged)
        random.shuffle(mixed_skills)
        n = args.n or 10
        mixed_skills = mixed_skills[:n]
        synthetic = {"week": "ALL", "title": "Cross-week mix", "skills": mixed_skills}
        result = run_quiz(synthetic, n=n, progress=progress)
        save_progress(progress)
        return 0

    try:
        week = int(target)
    except ValueError:
        print(f"error: invalid week '{target}'")
        return 2

    week_data = load_week(week)
    if not week_data:
        print(f"error: Week {week}/mastery.yml not found.")
        return 1

    # --review: interleave 80% current-week / 20% due-skill review.
    if getattr(args, "review", False):
        current_skills = list(week_data.get("skills", []))
        for s in current_skills:
            s["_week"] = week
        n_total = args.n or len(current_skills)
        n_review = max(1, n_total // 5)            # 20% review
        n_current = max(0, n_total - n_review)
        random.shuffle(current_skills)
        current_skills = current_skills[:n_current]
        due = collect_due_skills(progress, max_skills=n_review)
        if not due:
            print("(no due skills to interleave — running normal quiz)")
        skills = current_skills + due
        random.shuffle(skills)
        synthetic = {
            "week": week,
            "title": f"{week_data.get('title', '')} (with review)",
            "skills": skills,
        }
        result = run_quiz(synthetic, n=len(skills), progress=progress)
    else:
        result = run_quiz(week_data, n=args.n, progress=progress)

    # Persist latest snapshot per week (unchanged behaviour).
    progress["weeks"][str(week)] = result
    progress["current_week"] = max(progress.get("current_week", 1), week)

    # Append an entry to the rolling history (for streaks / time-to-mastery).
    now_iso = _dt.datetime.now().isoformat(timespec="seconds")
    history = progress.setdefault("history", [])
    history.append({
        "week": week,
        "passed": list(result.get("passed", [])),
        "missed": list(result.get("missed", [])),
        "total": result.get("total", 0),
        "rate": result.get("rate", 0),
        "timestamp": now_iso,
    })

    # Aggregate per-skill miss counts across all attempts.
    miss_counts = progress.setdefault("skill_miss_counts", {})
    for sid in result.get("missed", []):
        key = f"{week}:{sid}"
        miss_counts[key] = miss_counts.get(key, 0) + 1

    save_progress(progress)

    # Spaced-repetition suggestion at 80%+
    if result["rate"] >= 80:
        suggestions = []
        for offset in (3, 7):
            prev = week - offset
            if prev >= 1:
                suggestions.append(f"Week {prev}")
        if suggestions:
            print(
                "\nGreat work — for retention, revisit "
                + " and ".join(suggestions)
                + " (see docs/REVIEW_SCHEDULE.md)."
            )
    return 0


# ---------------------------------------------------------------------------
# HTML dashboard
# ---------------------------------------------------------------------------

DASHBOARD_FILE = PROGRESS_DIR / "dashboard.html"


def _parse_ts(ts: str) -> _dt.date | None:
    """Parse either ISO datetime or ISO date into a date."""
    if not ts or ts == "—":
        return None
    try:
        return _dt.date.fromisoformat(ts[:10])
    except Exception:
        return None


def _compute_streak(history: list[dict]) -> int:
    """Consecutive days (ending today or yesterday) with at least one quiz."""
    days = set()
    for h in history:
        d = _parse_ts(h.get("timestamp", ""))
        if d:
            days.add(d)
    if not days:
        return 0
    today = _dt.date.today()
    # Allow streak to "still be alive" if last entry was yesterday.
    if today not in days and (today - _dt.timedelta(days=1)) not in days:
        return 0
    start = today if today in days else today - _dt.timedelta(days=1)
    streak = 0
    cur = start
    while cur in days:
        streak += 1
        cur -= _dt.timedelta(days=1)
    return streak


def _top_missed_skills(progress: dict, k: int = 10) -> list[tuple[str, int, int]]:
    """Return [(week, skill_id, miss_count)] sorted desc by count."""
    counts = progress.get("skill_miss_counts", {})
    items: list[tuple[str, int, int]] = []
    for key, count in counts.items():
        if ":" not in key:
            continue
        week_s, sid = key.split(":", 1)
        try:
            week_n = int(week_s)
        except ValueError:
            continue
        items.append((sid, week_n, int(count)))
    items.sort(key=lambda t: (-t[2], t[1], t[0]))
    return items[:k]


def _time_to_mastery(history: list[dict]) -> dict[int, int]:
    """For each week the learner aced (rate>=100), days from 1st attempt to 100."""
    first_attempt: dict[int, _dt.date] = {}
    first_ace: dict[int, _dt.date] = {}
    for h in history:
        wk = h.get("week")
        if not isinstance(wk, int):
            continue
        d = _parse_ts(h.get("timestamp", ""))
        if not d:
            continue
        if wk not in first_attempt or d < first_attempt[wk]:
            first_attempt[wk] = d
        if h.get("rate", 0) >= 100 and wk not in first_ace:
            first_ace[wk] = d
        elif h.get("rate", 0) >= 100 and d < first_ace[wk]:
            first_ace[wk] = d
    out: dict[int, int] = {}
    for wk, ace_d in first_ace.items():
        start = first_attempt.get(wk, ace_d)
        out[wk] = (ace_d - start).days
    return out


def _recommend_next(progress: dict) -> dict:
    """Suggest a new week + 2 revisit problems following REVIEW_SCHEDULE.md."""
    weeks_seen = progress.get("weeks", {})
    # Highest attempted week, defaulting to current_week.
    attempted = [int(k) for k in weeks_seen.keys() if k.isdigit()]
    highest_attempted = max(attempted) if attempted else 0
    cur = max(progress.get("current_week", 1), highest_attempted)
    next_new = min(cur + 1, TOTAL_WEEKS)
    revisit = []
    for offset in (3, 7):
        prev = next_new - offset
        if prev >= 1:
            rec = weeks_seen.get(str(prev))
            note = ""
            if rec:
                ts = rec.get("timestamp", "")
                d = _parse_ts(ts)
                if d:
                    note = f" (last attempt {(_dt.date.today() - d).days}d ago)"
            revisit.append({"week": prev, "note": note})
    return {"next_new": next_new, "revisit": revisit}


def _week_status(rec: dict | None) -> tuple[str, str]:
    """Return (css_class, label) describing a week cell."""
    if not rec:
        return ("none", "not attempted")
    rate = rec.get("rate", 0) or 0
    if rate >= 80:
        return ("good", f"{rate:.0f}%")
    if rate >= 50:
        return ("mid", f"{rate:.0f}%")
    return ("bad", f"{rate:.0f}%")


def _esc(s) -> str:
    return _html.escape(str(s), quote=True)


def _render_dashboard(progress: dict) -> str:
    weeks_seen = progress.get("weeks", {})
    history = progress.get("history", [])
    streak = _compute_streak(history)
    top_missed = _top_missed_skills(progress, 10)
    ttm = _time_to_mastery(history)
    recommendation = _recommend_next(progress)
    generated = _dt.datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    # Cell colors come from the per-week web pages' palette
    # (#0d1117 bg, #161b22 card, #30363d border, #58a6ff blue, #3fb950 green).
    css = """
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d1117;--card:#161b22;--card-border:#30363d;
  --text:#c9d1d9;--text-secondary:#8b949e;
  --accent-blue:#58a6ff;--accent-green:#3fb950;
  --good:#22c55e;--mid:#eab308;--bad:#ef4444;--none:#374151;
  --gradient:linear-gradient(135deg,#58a6ff,#3fb950);
  --radius:12px;--shadow:0 4px 24px rgba(0,0,0,.4);
}
html{scroll-behavior:smooth}
body{
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;
  background:var(--bg);color:var(--text);line-height:1.6;
  padding:32px 20px 80px;max-width:1080px;margin:0 auto;
}
h1{font-size:2.2rem;font-weight:800;margin-bottom:6px;
   background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
h2{font-size:1.25rem;margin:0 0 16px;display:flex;align-items:center;gap:10px;color:var(--text)}
.subtitle{color:var(--text-secondary);font-size:.95rem;margin-bottom:28px}
.card{background:var(--card);border:1px solid var(--card-border);border-radius:var(--radius);
      padding:24px;margin:20px 0;box-shadow:var(--shadow)}
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:20px}
.stat{background:var(--card);border:1px solid var(--card-border);border-radius:var(--radius);
      padding:18px 20px;text-align:center}
.stat .val{font-size:2rem;font-weight:800;color:var(--accent-blue)}
.stat .lbl{font-size:.8rem;text-transform:uppercase;letter-spacing:1px;color:var(--text-secondary);margin-top:4px}
.heatmap{display:grid;grid-template-columns:repeat(10,1fr);gap:8px;margin-top:8px}
.cell{position:relative;aspect-ratio:1/1;border-radius:8px;cursor:pointer;
      display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;
      color:#0d1117;transition:transform .12s,box-shadow .12s;border:1px solid rgba(0,0,0,.2)}
.cell.good{background:var(--good)}
.cell.mid{background:var(--mid)}
.cell.bad{background:var(--bad)}
.cell.none{background:var(--none);color:var(--text-secondary)}
.cell:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(0,0,0,.5)}
.cell .tt{position:absolute;bottom:-6px;left:50%;transform:translate(-50%,100%);
          background:#000;color:#fff;padding:4px 8px;border-radius:6px;font-size:.72rem;
          white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .15s;z-index:5}
.cell:hover .tt{opacity:1}
.legend{display:flex;gap:14px;margin-top:14px;flex-wrap:wrap;font-size:.82rem;color:var(--text-secondary)}
.legend .sw{display:inline-block;width:14px;height:14px;border-radius:3px;vertical-align:middle;margin-right:6px}
.detail{display:none;margin-top:16px;padding:16px;background:rgba(88,166,255,.05);
        border-left:3px solid var(--accent-blue);border-radius:0 8px 8px 0;font-size:.9rem}
.detail.open{display:block}
.detail h3{font-size:1rem;color:var(--accent-blue);margin-bottom:8px}
.detail ul{margin:6px 0 6px 22px}
table{width:100%;border-collapse:collapse;margin:10px 0;font-size:.9rem}
th{background:rgba(88,166,255,.1);color:var(--accent-blue);text-align:left;padding:10px;
   border-bottom:2px solid var(--card-border);font-weight:600}
td{padding:8px 10px;border-bottom:1px solid var(--card-border)}
tr:hover td{background:rgba(88,166,255,.03)}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:.72rem;font-weight:600}
.badge-good{background:rgba(34,197,94,.15);color:var(--good)}
.badge-bad{background:rgba(239,68,68,.15);color:var(--bad)}
.footer{margin-top:40px;font-size:.78rem;color:var(--text-secondary);text-align:center}
ul.plain{list-style:none;padding:0}
ul.plain li{padding:6px 0;border-bottom:1px solid var(--card-border)}
ul.plain li:last-child{border-bottom:none}
@media(max-width:760px){
  .heatmap{grid-template-columns:repeat(6,1fr)}
  body{padding:20px 14px}
}
"""

    # Build heatmap cells
    cells_html = []
    week_details = {}
    for n in range(1, TOTAL_WEEKS + 1):
        rec = weeks_seen.get(str(n))
        cls, label = _week_status(rec)
        ts = rec.get("timestamp", "—") if rec else "—"
        passed = rec.get("passed", []) if rec else []
        missed = rec.get("missed", []) if rec else []
        total = rec.get("total", 0) if rec else 0
        tip = f"Week {n}: {label}"
        cells_html.append(
            f'<div class="cell {cls}" data-week="{n}" '
            f'onclick="toggleDetail({n})" title="{_esc(tip)}">'
            f"{n}<span class=\"tt\">{_esc(label)}</span></div>"
        )
        # Per-week skill details (rendered as a hidden block below the grid).
        detail_lines = [
            f'<div id="detail-{n}" class="detail">',
            f'<h3>Week {n} — {_esc(label)} (last attempt: {_esc(ts)})</h3>',
            f'<p>Skills tested: {total}</p>',
        ]
        if passed:
            detail_lines.append("<p><strong>Passed:</strong></p><ul>")
            for sid in passed:
                detail_lines.append(f"<li>{_esc(sid)}</li>")
            detail_lines.append("</ul>")
        if missed:
            detail_lines.append("<p><strong>Missed:</strong></p><ul>")
            for sid in missed:
                detail_lines.append(f"<li>{_esc(sid)}</li>")
            detail_lines.append("</ul>")
        if not rec:
            detail_lines.append("<p><em>Week not yet attempted.</em></p>")
        detail_lines.append("</div>")
        week_details[n] = "\n".join(detail_lines)

    # Top-line stats
    attempted = sum(1 for v in weeks_seen.values() if v)
    aced = sum(1 for v in weeks_seen.values() if v and v.get("rate", 0) >= 80)

    # Top missed skills table
    if top_missed:
        missed_rows = "\n".join(
            f"<tr><td>{wk}</td><td>{_esc(sid)}</td>"
            f'<td><span class="badge badge-bad">{cnt}</span></td></tr>'
            for sid, wk, cnt in top_missed
        )
        missed_table = (
            "<table><thead><tr><th>Week</th><th>Skill</th><th>Miss count</th>"
            f"</tr></thead><tbody>{missed_rows}</tbody></table>"
        )
    else:
        missed_table = "<p><em>No missed skills recorded yet.</em></p>"

    # Time-to-mastery table
    if ttm:
        ttm_rows = "\n".join(
            f"<tr><td>{wk}</td><td>{days} day{'s' if days != 1 else ''}</td></tr>"
            for wk, days in sorted(ttm.items())
        )
        ttm_table = (
            "<table><thead><tr><th>Week</th><th>Days to 100%</th>"
            f"</tr></thead><tbody>{ttm_rows}</tbody></table>"
        )
    else:
        ttm_table = (
            "<p><em>No 100% weeks yet — ace a week to see your time-to-mastery here.</em></p>"
        )

    # Recommended next session
    rec_items = [
        f"<li><strong>New: Week {recommendation['next_new']}</strong></li>"
    ]
    for r in recommendation["revisit"]:
        rec_items.append(
            f"<li>Revisit Week {r['week']}{_esc(r['note'])}</li>"
        )
    rec_html = "<ul class='plain'>" + "".join(rec_items) + "</ul>"

    details_html = "\n".join(week_details[n] for n in range(1, TOTAL_WEEKS + 1))

    js = """
function toggleDetail(n){
  document.querySelectorAll('.detail').forEach(function(d){
    if(d.id !== 'detail-'+n) d.classList.remove('open');
  });
  var el = document.getElementById('detail-'+n);
  if(el) el.classList.toggle('open');
}
"""

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DSA Journey — Progress Dashboard</title>
<style>{css}</style>
</head>
<body>
<h1>DSA Journey — Progress Dashboard</h1>
<p class="subtitle">Generated {_esc(generated)} from <code>~/.journey/progress.json</code></p>

<div class="stats">
  <div class="stat"><div class="val">{streak}</div><div class="lbl">Day streak</div></div>
  <div class="stat"><div class="val">{attempted}/{TOTAL_WEEKS}</div><div class="lbl">Weeks attempted</div></div>
  <div class="stat"><div class="val">{aced}</div><div class="lbl">Weeks aced (>=80%)</div></div>
  <div class="stat"><div class="val">{len(top_missed)}</div><div class="lbl">Distinct weak skills</div></div>
</div>

<div class="card">
  <h2>Mastery heatmap (30 weeks)</h2>
  <div class="heatmap">{''.join(cells_html)}</div>
  <div class="legend">
    <span><span class="sw" style="background:var(--good)"></span>>=80%</span>
    <span><span class="sw" style="background:var(--mid)"></span>50-79%</span>
    <span><span class="sw" style="background:var(--bad)"></span>&lt;50%</span>
    <span><span class="sw" style="background:var(--none)"></span>not attempted</span>
  </div>
  {details_html}
</div>

<div class="card">
  <h2>Top weak skills (most missed)</h2>
  {missed_table}
</div>

<div class="card">
  <h2>Recommended next session</h2>
  {rec_html}
  <p style="font-size:.82rem;color:var(--text-secondary);margin-top:8px">
    Based on <code>docs/REVIEW_SCHEDULE.md</code> — pair one new week with two
    revisits at N-3 and N-7 offsets.
  </p>
</div>

<div class="card">
  <h2>Time-to-mastery</h2>
  {ttm_table}
</div>

<div class="footer">
  Self-contained — no external CSS or JS. Refresh with
  <code>./scripts/journey progress --html</code>.
</div>

<script>{js}</script>
</body>
</html>
"""


def write_dashboard(progress: dict) -> Path:
    PROGRESS_DIR.mkdir(parents=True, exist_ok=True)
    html_str = _render_dashboard(progress)
    DASHBOARD_FILE.write_text(html_str)
    return DASHBOARD_FILE


def _open_in_browser(path: Path) -> None:
    url = path.resolve().as_uri()
    # Prefer xdg-open / open if available, else webbrowser stdlib.
    for cmd in ("xdg-open", "open"):
        try:
            subprocess.Popen(
                [cmd, str(path)],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
            return
        except FileNotFoundError:
            continue
    try:
        webbrowser.open(url)
    except Exception:
        pass


def cmd_progress(_args: argparse.Namespace) -> int:
    progress = load_progress()

    # HTML mode short-circuits the text table.
    if getattr(_args, "html", False):
        path = write_dashboard(progress)
        print(f"Wrote dashboard: {path}")
        if getattr(_args, "open", False):
            _open_in_browser(path)
        return 0

    weeks_seen = progress.get("weeks", {})

    # Validate every week's YAML parses too (silent — just count skills)
    print(f"{'Week':<5} {'Skills Tested':<14} {'Pass Rate':<10} {'Last Attempt':<14}")
    last_passed_week: int | None = None
    last_passed_date: str | None = None
    yaml_errors: list[str] = []
    for n in range(1, TOTAL_WEEKS + 1):
        try:
            data = load_week(n)
        except Exception as e:
            yaml_errors.append(f"Week {n}: {e}")
            data = None
        skill_count = len(data.get("skills", [])) if data else 0
        rec = weeks_seen.get(str(n))
        if rec:
            total = rec.get("total", 0)
            rate = rec.get("rate", 0)
            ts = rec.get("timestamp", "—")
            tested_col = f"{total}/{skill_count}" if skill_count else f"{total}"
            rate_col = f"{rate:.0f}%"
            print(f"{n:<5} {tested_col:<14} {rate_col:<10} {ts:<14}")
            if rate >= 80:
                last_passed_week = n
                last_passed_date = ts
        else:
            tested = "—" if not skill_count else f"0/{skill_count}"
            print(f"{n:<5} {tested:<14} {'—':<10} {'(not attempted)':<14}")

    # Suggestion
    cur = progress.get("current_week", 1)
    nxt = min(cur + 1, TOTAL_WEEKS)
    revisit = ""
    if last_passed_week and last_passed_date:
        try:
            d = _dt.date.fromisoformat(last_passed_date)
            days = (_dt.date.today() - d).days
            revisit = f" — or revisit Week {last_passed_week} (last passed {days} days ago)"
        except Exception:
            pass
    print(f"\nSuggested next: Week {nxt}{revisit}")

    if yaml_errors:
        print("\nYAML errors:")
        for e in yaml_errors:
            print("  " + e)
        return 1
    return 0


def cmd_reset(args: argparse.Namespace) -> int:
    progress = load_progress()
    week_key = str(args.week)
    if week_key in progress.get("weeks", {}):
        del progress["weeks"][week_key]
        save_progress(progress)
        print(f"Reset Week {args.week} progress.")
    else:
        print(f"No progress recorded for Week {args.week}.")
    return 0


def cmd_dashboard(_args: argparse.Namespace) -> int:
    """Shortcut: equivalent to `progress --html --open`."""
    ns = argparse.Namespace(html=True, open=True)
    return cmd_progress(ns)


def cmd_default(_args: argparse.Namespace) -> int:
    progress = load_progress()
    cur = progress.get("current_week", 1)
    print(f"Resuming at Week {cur}. Use `journey quiz {cur}` to start.")
    return cmd_progress(_args)


# ---------------------------------------------------------------------------
# Daily-drip practice
# ---------------------------------------------------------------------------

# Reflection prompts cycle deterministically by day-of-year.
_REFLECTION_PROMPTS = [
    "What's one pattern you would have *missed* yesterday but caught today?",
    "Name one bug you wrote this week that you've also written before. Why?",
    "Which data structure are you most likely to over-reach for, and what's a cheaper alternative?",
    "If you had to teach yesterday's hardest problem to a peer in three sentences, what would they be?",
    "What is one piece of vocabulary you're still using by rote, without truly understanding?",
    "Which complexity claim in your recent solution would you be embarrassed to defend out loud?",
    "What's the smallest input that would have broken your last solution? Did you test it?",
    "When did you peek at the answer in the last 24 hours? What hint would have been enough?",
    "Of the last 5 problems you solved, which one would you bet you'd fail to re-solve next week?",
    "What's one trick from a *different* week you could have used on today's problem?",
    "Name the highest-leverage habit you could add to your daily loop in under 5 minutes.",
    "What surprised you about your solution after you wrote it?",
    "Which step of the four-step methodology (decompose / recognize / implement / journal) did you skip today?",
    "What does 'I understood this' feel like, concretely, for the topic you just studied?",
]


def _parse_drill_lines(path: Path) -> list[dict]:
    """Lightweight parser for `### N. prose` lines inside patterns.md."""
    if not path.exists():
        return []
    drills: list[dict] = []
    end_idx = None
    lines = path.read_text(encoding="utf-8").splitlines()
    for i, ln in enumerate(lines):
        if ln.strip().lower().startswith("## answer key"):
            end_idx = i
            break
    if end_idx is None:
        end_idx = len(lines)
    pat = re.compile(r"^###\s+(\d+)\.\s+(.*)$")
    for i in range(end_idx):
        m = pat.match(lines[i])
        if m:
            drills.append({"n": int(m.group(1)), "prose": m.group(2).strip()})
    return drills


def _parse_challenge_titles(path: Path) -> list[dict]:
    if not path.exists():
        return []
    out: list[dict] = []
    pat = re.compile(r"^##\s+Challenge\s+(\d+):\s*(.*)$", re.IGNORECASE)
    for ln in path.read_text(encoding="utf-8").splitlines():
        m = pat.match(ln)
        if m:
            out.append({"n": int(m.group(1)), "title": m.group(2).strip()})
    return out


def _revisit_week(current_week: int) -> int | None:
    """Pick the revisit week per REVIEW_SCHEDULE: prefer N-3, fall back N-7."""
    if current_week - 3 >= 1:
        return current_week - 3
    if current_week - 7 >= 1:
        return current_week - 7
    return None


def _build_daily_plan(today: _dt.date | None = None) -> dict:
    """Return the deterministic plan dict for the given date."""
    if today is None:
        today = _dt.date.today()
    progress = load_progress()
    current_week = progress.get("current_week", 1)

    # Deterministic day index (epoch-based, stable across timezones).
    day_idx = today.toordinal()

    # Pattern drill: deterministic on (date, current_week).
    drill_path = REPO_ROOT / f"Week {current_week}" / "patterns.md"
    drills = _parse_drill_lines(drill_path)
    drill: dict | None = None
    if drills:
        d = drills[(day_idx + current_week) % len(drills)]
        drill = {"week": current_week, "n": d["n"], "prose": d["prose"], "path": drill_path}

    # Challenge: prefer revisit week (N-3 then N-7), else current week.
    challenge_week = _revisit_week(current_week) or current_week
    ch_path = REPO_ROOT / f"Week {challenge_week}" / "challenges.md"
    challenges = _parse_challenge_titles(ch_path)
    challenge: dict | None = None
    if challenges:
        c = challenges[day_idx % len(challenges)]
        challenge = {"week": challenge_week, "n": c["n"], "title": c["title"], "path": ch_path}

    # Mastery quiz topic: pick a skill id from current week's mastery.yml.
    week_data = load_week(current_week)
    quiz_topic: dict | None = None
    if week_data:
        skills = week_data.get("skills", []) or []
        if skills:
            s = skills[day_idx % len(skills)]
            quiz_topic = {
                "week": current_week,
                "id": s.get("id", "?"),
                "prompt": s.get("prompt", ""),
                "type": s.get("type", "open"),
            }

    reflection = _REFLECTION_PROMPTS[day_idx % len(_REFLECTION_PROMPTS)]

    return {
        "date": today.isoformat(),
        "current_week": current_week,
        "drill": drill,
        "challenge": challenge,
        "quiz_topic": quiz_topic,
        "reflection": reflection,
        "estimated_minutes": 25,
    }


def _format_daily_text(plan: dict) -> str:
    lines: list[str] = []
    lines.append(f"Daily Practice — {plan['date']} (Week {plan['current_week']})")
    lines.append("=" * 60)
    lines.append(f"Estimated time: {plan['estimated_minutes']} minutes")
    lines.append("")

    drill = plan["drill"]
    lines.append("1. Pattern drill")
    if drill:
        lines.append(f"   (Week {drill['week']}, drill #{drill['n']})")
        lines.append(f"   {drill['prose']}")
    else:
        lines.append("   (no drill available)")
    lines.append("")

    challenge = plan["challenge"]
    lines.append("2. Challenge")
    if challenge:
        lines.append(
            f"   Week {challenge['week']} — Challenge {challenge['n']}: {challenge['title']}"
        )
    else:
        lines.append("   (no challenge available)")
    lines.append("")

    quiz = plan["quiz_topic"]
    lines.append("3. Mastery quiz topic")
    if quiz:
        lines.append(f"   Skill: {quiz['id']} ({quiz['type']})")
        lines.append(f"   Prompt: {quiz['prompt']}")
        lines.append(f"   Run: ./scripts/journey quiz {quiz['week']} --n 1")
    else:
        lines.append("   (no mastery skills available)")
    lines.append("")

    lines.append("4. Reflection")
    lines.append(f"   {plan['reflection']}")
    return "\n".join(lines)


def _format_daily_markdown(plan: dict) -> str:
    lines: list[str] = []
    lines.append(f"# Daily Practice — {plan['date']}")
    lines.append("")
    lines.append(
        f"_Current week: **{plan['current_week']}**. Estimated time: "
        f"**{plan['estimated_minutes']} minutes**._"
    )
    lines.append("")

    drill = plan["drill"]
    lines.append("## 1. Pattern drill")
    if drill:
        rel = drill["path"].relative_to(REPO_ROOT) if drill["path"].exists() else drill["path"]
        lines.append(f"From Week {drill['week']} (drill #{drill['n']}):")
        lines.append("")
        lines.append(f"> {drill['prose']}")
        lines.append("")
        lines.append(
            f"Name the pattern in one word; justify in one sentence. Source: `{rel}`."
        )
    else:
        lines.append("_(no drill available)_")
    lines.append("")

    challenge = plan["challenge"]
    lines.append("## 2. Challenge")
    if challenge:
        rel = challenge["path"].relative_to(REPO_ROOT) if challenge["path"].exists() else challenge["path"]
        lines.append(
            f"**Week {challenge['week']} — Challenge {challenge['n']}: {challenge['title']}**"
        )
        lines.append("")
        if challenge["week"] != plan["current_week"]:
            lines.append(
                f"_Revisit pick (N-3 / N-7 per docs/REVIEW_SCHEDULE.md)._"
            )
            lines.append("")
        lines.append(f"Spec: `{rel}`")
    else:
        lines.append("_(no challenge available)_")
    lines.append("")

    quiz = plan["quiz_topic"]
    lines.append("## 3. Mastery quiz topic")
    if quiz:
        lines.append(f"- **Skill**: `{quiz['id']}` ({quiz['type']})")
        lines.append(f"- **Prompt**: {quiz['prompt']}")
        lines.append("")
        lines.append(f"Run `./scripts/journey quiz {quiz['week']} --n 1` to drill this in isolation.")
    else:
        lines.append("_(no mastery skills available)_")
    lines.append("")

    lines.append("## 4. Reflection prompt")
    lines.append("")
    lines.append(f"> {plan['reflection']}")
    lines.append("")
    lines.append(
        "Write a 2-3 sentence answer in `docs/SOLUTION_JOURNAL.md` or your own notes."
    )
    lines.append("")
    lines.append("---")
    lines.append("")
    lines.append(
        "Auto-generated. See [`docs/DAILY_PRACTICE.md`](docs/DAILY_PRACTICE.md) for how this list is built."
    )
    return "\n".join(lines)


def cmd_daily(args: argparse.Namespace) -> int:
    plan = _build_daily_plan()
    if getattr(args, "markdown", False):
        sys.stdout.write(_format_daily_markdown(plan) + "\n")
    else:
        sys.stdout.write(_format_daily_text(plan) + "\n")
    return 0


# ---------------------------------------------------------------------------
# Review (FSRS-driven)
# ---------------------------------------------------------------------------

def cmd_review(args: argparse.Namespace) -> int:
    """Run only skills that are due today, across all weeks, in priority order."""
    progress = load_progress()
    max_n = getattr(args, "n", None)
    due = collect_due_skills(progress, max_skills=max_n)
    if not due:
        print("No skills are due for review right now.")
        print("Quiz a week first (./scripts/journey quiz N) to seed the schedule,")
        print("or come back later — review intervals grow as you keep up with them.")
        return 0
    print(f"Due for review: {len(due)} skill(s) (oldest first).")
    synthetic = {"week": "REVIEW", "title": "FSRS due-skill review", "skills": due}
    run_quiz(synthetic, n=len(due), progress=progress)
    save_progress(progress)
    return 0


# ---------------------------------------------------------------------------
# Argparse
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="journey", description="DSA-journey mastery CLI.")
    sub = p.add_subparsers(dest="cmd")

    q = sub.add_parser("quiz", help="Run a quiz")
    q.add_argument("target", help="Week number or 'all'")
    q.add_argument("--n", type=int, default=None, help="Limit number of questions")
    q.add_argument(
        "--review",
        action="store_true",
        help="Interleave 80% current-week skills with 20% due-for-review skills (FSRS).",
    )
    q.set_defaults(func=cmd_quiz)

    rv = sub.add_parser(
        "review",
        help="Quiz only skills that are due now (FSRS), across all weeks.",
    )
    rv.add_argument(
        "--n",
        type=int,
        default=None,
        help="Cap number of due skills to review this session.",
    )
    rv.set_defaults(func=cmd_review)

    pr = sub.add_parser("progress", help="Show progress table")
    pr.add_argument(
        "--html",
        action="store_true",
        help="Write a self-contained HTML dashboard to ~/.journey/dashboard.html",
    )
    pr.add_argument(
        "--open",
        action="store_true",
        help="With --html, also open the dashboard in the default browser",
    )
    pr.set_defaults(func=cmd_progress)

    d = sub.add_parser(
        "dashboard",
        help="Shortcut for `progress --html --open`",
    )
    d.set_defaults(func=cmd_dashboard)

    r = sub.add_parser("reset", help="Reset a week's progress")
    r.add_argument("week", type=int)
    r.set_defaults(func=cmd_reset)

    dly = sub.add_parser("daily", help="Print today's recommended practice (25 min)")
    dly.add_argument(
        "--markdown",
        action="store_true",
        help="Render as Markdown (suitable for piping into emails / issues)",
    )
    dly.set_defaults(func=cmd_daily)

    return p


def main(argv: list[str]) -> int:
    parser = build_parser()
    if not argv:
        return cmd_default(argparse.Namespace())
    args = parser.parse_args(argv)
    if not hasattr(args, "func"):
        return cmd_default(args)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
